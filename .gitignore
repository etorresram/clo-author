# ==============================================================================
# .gitignore for Academic Claude Code Projects
# ==============================================================================

# LaTeX build artifacts
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.nav
*.out
*.snm
*.toc
*.vrb
*.synctex.gz
*.run.xml
*-blx.bib

# Compiled PDFs (uncomment to track specific PDFs)
# *.pdf

# Reference library PDFs — local-only, copyright-sensitive, often large
master_supporting_docs/supporting_papers/**/*.pdf
master_supporting_docs/supporting_slides/**/*.pdf
master_supporting_docs/**/.DS_Store

# Raw survey microdata — confidential, large, not redistributable
# The entire data/raw directory (or its symlink to an external data store)
# is local-only. The user sets this up on each machine independently.
# See data/raw/README.md (in main repo) for structure and naming convention.
/data/raw

# Cleaned data intermediate files
data/cleaned/**/*.rds
data/cleaned/**/*.parquet
data/cleaned/**/*.feather
# Allow small metadata/codebooks in cleaned/
!data/cleaned/**/README.md
!data/cleaned/**/codebook.*

# Python
__pycache__/
*.pyc
*.pyo

# R
.Rproj.user/
.Rhistory
.RData
.Rdata

# OS files
.DS_Store
Thumbs.db

# Claude Code local files (not shared across machines)
.claude/settings.local.json
.claude/state/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Quarto rendering artifacts
/.quarto/
paper/quarto/*_files/
paper/quarto/.quarto/

# Output artifacts — uncomment lines below based on your preference
# *.rds
# output/**/*.rds
docs/

# Scheduled tasks runtime state (local)
.claude/scheduled_tasks.lock
